# LLM API endpoint — HuggingFace Inference Router (OpenAI-compatible)
# For OpenAI: https://api.openai.com/v1
# For HF:     https://router.huggingface.co/v1
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier. Must be available on your chosen provider.
# Reliable HF serverless models:
#   Qwen/Qwen2.5-72B-Instruct
#   meta-llama/Llama-3.3-70B-Instruct
#   mistralai/Mistral-7B-Instruct-v0.3
# For OpenAI:
#   gpt-4.1-mini
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Your Hugging Face token (required — get it from https://hf.co/settings/tokens)
HF_TOKEN=your_hf_token_here

# HealthClaim-Env server URL (inference.py connects here via WebSocket client)
# Leave as-is when running locally. For remote/HF Space: set to the Space URL.
# The inference script will auto-start the server on localhost:8000 if not running.
ENV_URL=http://localhost:8000

# (Optional) Name/tag of a locally-built Docker image to use when auto-starting
# the server and docker-compose.yml is not available.
# Example:  LOCAL_IMAGE_NAME=healthisure:latest
# Build first with:  docker build -t healthisure:latest .
# LOCAL_IMAGE_NAME=


